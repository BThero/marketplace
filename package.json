{
  "name": "marketplace",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "tsx watch src/index.tsx",
    "build": "tsc",
    "start": "node dist/index.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "types": "tsc --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm types",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "1.19.3",
    "dotenv": "17.2.2",
    "drizzle-orm": "0.32.0",
    "hono": "4.9.8",
    "pg": "8.16.3",
    "zod": "4.1.9"
  },
  "devDependencies": {
    "@types/node": "22.18.6",
    "@types/pg": "8.15.5",
    "drizzle-kit": "0.23.0",
    "prettier": "3.5.3",
    "tsx": "4.20.5",
    "typescript": "5.9.2"
  }
}
